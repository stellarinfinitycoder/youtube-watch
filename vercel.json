{
  "rewrites": [
    {
      "source": "/api/youtube/:route*",
      "destination": "/api/youtube?route=:route*"
    },
    {
      "source": "/rss.xml",
      "destination": "/api/rss"
    },
    {
      "source": "/news",
      "destination": "/index.html"
    },
    {
      "source": "/news/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/admin/rssfeed",
      "destination": "/index.html"
    },
    {
      "source": "/admin/rssfeed/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/admin/publisher",
      "destination": "/index.html"
    },
    {
      "source": "/admin/publisher/(.*)",
      "destination": "/index.html"
    }
  ]
}
